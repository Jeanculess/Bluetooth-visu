/* Bauhaus Temperature Dashboard
   Arduino IoT Cloud + ThingSpeak + SSD1351 OLED 128x128
   Dual sparklines · Anti-burn · Trend indicators
*/

#include "thingProperties.h"
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1351.h>
#include <SPI.h>
#include <time.h>

// ── ThingSpeak ───────────────────────────────────────────────────────────────
const String CHANNEL_ID   = "TON_CHANNEL_ID";
const String READ_API_KEY = "TA_CLE_API";

// ThingSpeak field numbers for each sensor
#define FIELD_INT_TEMP "field1"
#define FIELD_EXT_TEMP "field3"

// ── OLED pins (ESP32) ────────────────────────────────────────────────────────
#define SCLK_PIN 18
#define MOSI_PIN 23
#define DC_PIN   17
#define CS_PIN    5
#define RST_PIN  16

#define SCREEN_W 128
#define SCREEN_H 128

// ── Colour palette (RGB565) ──────────────────────────────────────────────────
#define BLACK    0x0000
#define WHITE    0xFFFF
#define RED      0xF800  // Interior accent
#define CYAN     0x07FF  // Exterior accent
#define YELLOW   0xFFE0  // Bauhaus separators / title
#define DARKRED  0x6000  // Interior panel fill  (dark red)
#define DARKCYAN 0x032C  // Exterior panel fill  (dark teal)
#define DRKGREY  0x39E7  // Grid lines / axis separator

// ── Timing ───────────────────────────────────────────────────────────────────
const unsigned long FETCH_INTERVAL = 120000UL;  // 2 min
const unsigned long SHIFT_INTERVAL =  60000UL;  // 1 min

static unsigned long lastFetchTime = 0;
static unsigned long lastShiftTime = 0;

// ── Anti-burn offset (±1 px, applied to text & data only) ───────────────────
static int ox = 0, oy = 0;

// ── Data ─────────────────────────────────────────────────────────────────────
static String currentTempInt = "--.-";
static String currentTempExt = "--.-";
static float  tempIntHistory[20];
static float  tempExtHistory[20];
static int    historyCount = 0;

Adafruit_SSD1351 tft(SCREEN_W, SCREEN_H, CS_PIN, DC_PIN, MOSI_PIN, SCLK_PIN, RST_PIN);

// ── Graph scaling constants ───────────────────────────────────────────────────
// Minimum temperature range before padding is applied (prevents a flat line)
#define GRAPH_MIN_RANGE   0.1f
// Padding added above/below when the measured range is too narrow to display
#define GRAPH_RANGE_PAD   0.5f

// ── Forward declarations ─────────────────────────────────────────────────────
void fetchThingSpeak();
void drawBauhausDashboard();
void drawSingleGraph(const float* vals, int count,
                     int x, int y, int w, int h,
                     uint16_t color, const char* label);
void drawSplashScreen();

// ── Format a raw API float string to one decimal place ───────────────────────
static String formatTemperature(const char* raw) {
  if (!raw || raw[0] == '\0') return "--.-";
  char buf[8];
  snprintf(buf, sizeof(buf), "%.1f", atof(raw));
  return String(buf);
}

// ── Build "HH:MM" or "--:--" when NTP is not yet synced ─────────────────────
static void getTimeString(char* out, size_t len) {
  time_t now;
  time(&now);
  struct tm ti;
  localtime_r(&now, &ti);
  // tm_year is years since 1900; year 2020 = 120
  if (ti.tm_year < 120) {
    strlcpy(out, "--:--", len);
  } else {
    strftime(out, len, "%H:%M", &ti);
  }
}

// ── Trend character: '^' rising · 'v' falling · '-' flat ────────────────────
static char trendChar(const float* vals, int count) {
  if (count < 2) return ' ';
  float d = vals[count - 1] - vals[count - 2];
  if (d >  0.2f) return '^';
  if (d < -0.2f) return 'v';
  return '-';
}

// ── Map a data value onto a pixel Y coordinate within the graph box ──────────
static int scaleValueToY(float val, float minVal, float range, int y, int h) {
  return constrain(y + h - 1 - (int)((val - minVal) / range * (h - 1)), y, y + h - 1);
}

// ────────────────────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(9600);
  delay(1500);

  initProperties();
  ArduinoCloud.begin(ArduinoIoTPreferredConnection);
  setDebugMessageLevel(2);
  ArduinoCloud.printDebugInfo();

  tft.begin();
  tft.fillScreen(BLACK);
  drawSplashScreen();

  // configTzTime links NTP + POSIX timezone in a single call (ESP32 Arduino >=1.0.4).
  // This prevents the SNTP sync callback from silently resetting the timezone to UTC.
  configTzTime("EST5EDT,M3.2.0,M11.1.0", "pool.ntp.org", "time.nist.gov");
}

// ────────────────────────────────────────────────────────────────────────────
void loop() {
  ArduinoCloud.update();

  // Anti-burn: shift text/data ±1 px every SHIFT_INTERVAL ms
  if (millis() - lastShiftTime > SHIFT_INTERVAL) {
    ox = random(-1, 2);
    oy = random(-1, 2);
    lastShiftTime = millis();
    if (historyCount > 0) drawBauhausDashboard();
  }

  // Periodic ThingSpeak fetch
  if ((lastFetchTime == 0 || millis() - lastFetchTime > FETCH_INTERVAL)
      && ArduinoCloud.connected()) {
    fetchThingSpeak();
    lastFetchTime = millis();
  }
}

// ────────────────────────────────────────────────────────────────────────────
void drawSplashScreen() {
  tft.fillRect(4, 40, 120, 48, YELLOW);
  tft.setTextColor(BLACK);
  tft.setTextSize(2);
  tft.setCursor(10, 48);
  tft.print("BAUHAUS");
  tft.setTextSize(1);
  tft.setCursor(14, 68);
  tft.print("TEMP DASHBOARD");
  tft.setTextColor(DRKGREY);
  tft.setCursor(20, 96);
  tft.print("Connecting...");
}

// ────────────────────────────────────────────────────────────────────────────
void fetchThingSpeak() {
  String url = "https://api.thingspeak.com/channels/" + CHANNEL_ID
             + "/feeds.json?api_key=" + READ_API_KEY + "&results=20";

  HTTPClient http;
  http.begin(url);
  int code = http.GET();

  if (code > 0) {
    String payload = http.getString();
    StaticJsonDocument<4096> doc;
    DeserializationError err = deserializeJson(doc, payload);

    if (!err) {
      JsonArray feeds = doc["feeds"].as<JsonArray>();
      if (!feeds.isNull()) {
        historyCount = min((int)feeds.size(), 20);
        if (historyCount > 0) {
          JsonObject latest = feeds[historyCount - 1];
          currentTempInt = formatTemperature(latest[FIELD_INT_TEMP] | "");
          currentTempExt = formatTemperature(latest[FIELD_EXT_TEMP] | "");
          for (int i = 0; i < historyCount; i++) {
            tempIntHistory[i] = feeds[i][FIELD_INT_TEMP] | 0.0f;
            tempExtHistory[i] = feeds[i][FIELD_EXT_TEMP] | 0.0f;
          }
          drawBauhausDashboard();
        }
      }
    } else {
      Serial.print(F("JSON parse error: "));
      Serial.println(err.f_str());
    }
  } else {
    Serial.print(F("HTTP error: "));
    Serial.println(code);
  }
  http.end();
}

// ────────────────────────────────────────────────────────────────────────────
void drawBauhausDashboard() {
  tft.fillScreen(BLACK);

  char timeStr[10];
  getTimeString(timeStr, sizeof(timeStr));

  // ── HEADER  (Y 0..12) ──────────────────────────────────────────────────────
  // "BAUHAUS TEMP" = 12 chars x 6 px = 72 px  |  "HH:MM" = 5 chars at X=92
  tft.setTextSize(1);
  tft.setTextColor(YELLOW);
  tft.setCursor(2 + ox, 2 + oy);
  tft.print("BAUHAUS TEMP");
  tft.setTextColor(WHITE);
  tft.setCursor(92 + ox, 2 + oy);
  tft.print(timeStr);
  // Full-width accent bar: no ox/oy so it always spans the entire screen
  tft.fillRect(0, 11, SCREEN_W, 2, YELLOW);

  // ── VALUE PANELS  (Y 14..37) ───────────────────────────────────────────────
  //   Left  (X   0..62) = Interior
  //   Right (X  65..127) = Exterior
  // Panel fills/borders are structural (no ox/oy); only text & indicators shift.

  // Interior panel
  tft.fillRect(0,  14, 63, 24, DARKRED);
  tft.drawRect(0,  14, 63, 24, RED);
  tft.fillCircle(5 + ox, 20 + oy, 2, RED);
  tft.setTextColor(RED);
  tft.setCursor(11 + ox, 16 + oy);
  tft.print("INT");
  tft.setTextColor(WHITE);
  tft.setCursor(4 + ox, 26 + oy);
  tft.print(currentTempInt);
  tft.print((char)247);  // °
  tft.print("C");
  tft.setTextColor(RED);
  tft.print(' ');
  tft.print(trendChar(tempIntHistory, historyCount));

  // Exterior panel
  tft.fillRect(65, 14, 63, 24, DARKCYAN);
  tft.drawRect(65, 14, 63, 24, CYAN);
  tft.fillCircle(70 + ox, 20 + oy, 2, CYAN);
  tft.setTextColor(CYAN);
  tft.setCursor(76 + ox, 16 + oy);
  tft.print("EXT");
  tft.setTextColor(WHITE);
  tft.setCursor(69 + ox, 26 + oy);
  tft.print(currentTempExt);
  tft.print((char)247);  // °
  tft.print("C");
  tft.setTextColor(CYAN);
  tft.print(' ');
  tft.print(trendChar(tempExtHistory, historyCount));

  // ── GRAPH 1 : INTERIOR  (Y 39..83, h=45) ───────────────────────────────────
  drawSingleGraph(tempIntHistory, historyCount, 20, 39, 107, 45, RED,  "INT");

  // ── MID SEPARATOR  (Y 84..85) ──────────────────────────────────────────────
  tft.fillRect(0, 84, SCREEN_W, 2, YELLOW);

  // ── GRAPH 2 : EXTERIOR  (Y 87..127, h=41) ──────────────────────────────────
  drawSingleGraph(tempExtHistory, historyCount, 20, 87, 107, 41, CYAN, "EXT");
}

// ────────────────────────────────────────────────────────────────────────────
void drawSingleGraph(const float* vals, int count,
                     int x, int y, int w, int h,
                     uint16_t color, const char* label) {
  if (count < 1) return;

  float minVal = vals[0], maxVal = vals[0];
  for (int i = 1; i < count; i++) {
    if (vals[i] < minVal) minVal = vals[i];
    if (vals[i] > maxVal) maxVal = vals[i];
  }
  if (maxVal - minVal < GRAPH_MIN_RANGE) { maxVal += GRAPH_RANGE_PAD; minVal -= GRAPH_RANGE_PAD; }
  const float range = maxVal - minVal;

  // Y-axis integer labels (no "°C" suffix – keeps them within the 0..18 px column)
  tft.setTextSize(1);
  tft.setTextColor(color);
  tft.setCursor(0 + ox, y + oy);
  tft.print((int)round(maxVal));
  tft.setCursor(0 + ox, y + h - 8 + oy);
  tft.print((int)round(minVal));

  // Y-axis separator line and graph border: structural elements, no ox/oy
  tft.drawLine(19, y, 19, y + h - 1, DRKGREY);
  tft.drawRect(x, y, w, h, WHITE);

  // Mid-line grid
  tft.drawLine(x, y + h / 2, x + w - 1, y + h / 2, DRKGREY);

  // Section label inside top-left corner of box (shifts with anti-burn)
  tft.setTextColor(color);
  tft.setCursor(x + 2 + ox, y + 2 + oy);
  tft.print(label);

  // Data lines (double-pixel for readability on a small display)
  for (int i = 0; i < count - 1; i++) {
    int x1 = x + (int)(i       * (w - 1) / (float)(count - 1));
    int x2 = x + (int)((i + 1) * (w - 1) / (float)(count - 1));
    int y1 = scaleValueToY(vals[i],     minVal, range, y, h);
    int y2 = scaleValueToY(vals[i + 1], minVal, range, y, h);
    tft.drawLine(x1 + ox, y1 + oy,     x2 + ox, y2 + oy,     color);
    tft.drawLine(x1 + ox, y1 + 1 + oy, x2 + ox, y2 + 1 + oy, color);
  }

  // Highlight the latest data point with a white dot
  int lx = x + w - 1;
  int ly = scaleValueToY(vals[count - 1], minVal, range, y, h);
  tft.fillCircle(lx + ox, ly + oy, 2, WHITE);
}

// ────────────────────────────────────────────────────────────────────────────
// Arduino Cloud generated callbacks go here
// ────────────────────────────────────────────────────────────────────────────
