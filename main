/* Sketch generated by the Arduino IoT Cloud Thing
  Integrated with ThingSpeak, Dual Distinct Sparklines, Anti-Burn, and Bauhaus UI
*/

#include "thingProperties.h"
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1351.h>
#include <SPI.h>
#include <time.h>

// --- THINGSPEAK CONFIGURATION ---
const String CHANNEL_ID = "TON_CHANNEL_ID";
const String READ_API_KEY = "TA_CLE_API";

// --- OLED PINS (ESP32) ---
#define SCLK_PIN 18
#define MOSI_PIN 23
#define DC_PIN   17
#define CS_PIN   5
#define RST_PIN  16

#define SCREEN_WIDTH  128
#define SCREEN_HEIGHT 128

// --- BAUHAUS PRIMARY PALETTE ---
#define BLACK   0x0000
#define WHITE   0xFFFF
#define RED     0xF800 // Intérieur
#define BLUE    0x03FF // Extérieur (Cyan clair)
#define YELLOW  0xFFE0 // Structure
#define DRKGREY 0x39E7 // Grilles et séparateurs

Adafruit_SSD1351 tft = Adafruit_SSD1351(SCREEN_WIDTH, SCREEN_HEIGHT, CS_PIN, DC_PIN, MOSI_PIN, SCLK_PIN, RST_PIN);

// --- TIMERS & ANTI-BURN ---
unsigned long lastFetchTime = 0;
const unsigned long fetchDelay = 120000; // 2 minutes

unsigned long lastShiftTime = 0;
const unsigned long shiftDelay = 60000;  // 1 minute

int ox = 0; // Offset X
int oy = 0; // Offset Y

// --- DATA STORAGE ---
String currentTempInt = "--";
String currentTempExt = "--";

float tempIntHistory[20];
float tempExtHistory[20];
int historyCount = 0;

void setup() {
  Serial.begin(9600);
  delay(1500); 

  initProperties();
  ArduinoCloud.begin(ArduinoIoTPreferredConnection);
  setDebugMessageLevel(2);
  ArduinoCloud.printDebugInfo();

  // --- OLED INIT ---
  tft.begin();
  tft.fillScreen(BLACK);
  
  tft.fillRect(10, 50, 108, 28, YELLOW);
  tft.setTextColor(BLACK);
  tft.setTextSize(1);
  tft.setCursor(15, 60);
  tft.println("SYSTEM INIT...");

  // --- TIME ZONE FORCE (Montréal EST/EDT) ---
  configTime(0, 0, "pool.ntp.org", "time.nist.gov");
  setenv("TZ", "EST5EDT,M3.2.0,M11.1.0", 1);
  tzset();
}

void loop() {
  ArduinoCloud.update();
  
  // 1. Anti-Burn Mechanism (Restreint à 1 pixel pour ne pas détruire la grille)
  if (millis() - lastShiftTime > shiftDelay) {
    ox = random(-1, 2); 
    oy = random(-1, 2);
    lastShiftTime = millis();
    
    if (historyCount > 0) {
      drawBauhausDashboard();
    }
  }

  // 2. API Fetch
  if ((millis() - lastFetchTime > fetchDelay || lastFetchTime == 0) && ArduinoCloud.connected()) {
    fetchThingSpeak();
    lastFetchTime = millis();
  }
}

// --- CUSTOM LOGIC ---

void fetchThingSpeak() {
  String url = "https://api.thingspeak.com/channels/" + CHANNEL_ID + "/feeds.json?api_key=" + READ_API_KEY + "&results=20";
  
  HTTPClient http;
  http.begin(url);
  int httpResponseCode = http.GET();
  
  if (httpResponseCode > 0) {
    String payload = http.getString();
    DynamicJsonDocument doc(4096); 
    deserializeJson(doc, payload);
    
    JsonArray feeds = doc["feeds"];
    historyCount = feeds.size();
    
    if (historyCount > 0) {
      JsonObject latest = feeds[historyCount - 1];
      
      currentTempInt = latest["field1"].as<String>();
      currentTempExt = latest["field3"].as<String>();
      
      for(int i = 0; i < historyCount; i++) {
        tempIntHistory[i] = feeds[i]["field1"].as<float>();
        tempExtHistory[i] = feeds[i]["field3"].as<float>();
      }
      drawBauhausDashboard();
    }
  }
  http.end();
}

void drawBauhausDashboard() {
  tft.fillScreen(BLACK);
  
  // --- GESTION ROBUSTE DE L'HEURE ---
  time_t now;
  time(&now);
  struct tm timeinfo;
  localtime_r(&now, &timeinfo);
  
  char timeStr[10];
  // Si l'année est < 2020, c'est que le NTP n'a pas encore synchronisé
  if(timeinfo.tm_year < 120){
    strcpy(timeStr, "SYNC...");
  } else {
    strftime(timeStr, sizeof(timeStr), "%H:%M", &timeinfo);
  }

  // --- 1. HEADER (Y: 0 à 10) ---
  tft.setTextColor(WHITE);
  tft.setTextSize(1);
  tft.setCursor(0 + ox, 0 + oy);
  tft.print("SYS:");
  tft.print(timeStr);
  
  tft.fillRect(0 + ox, 10 + oy, 128, 2, YELLOW);

  // --- 2. VALEURS ACTUELLES (Y: 15 à 23) ---
  // INTÉRIEUR
  tft.fillRect(0 + ox, 15 + oy, 8, 8, RED); 
  tft.setCursor(11 + ox, 15 + oy);
  tft.setTextColor(WHITE);
  tft.print("IN:");
  tft.print(currentTempInt);
  tft.print((char)247); // Symbole Degré
  tft.print("C");

  // EXTÉRIEUR
  tft.fillRect(66 + ox, 15 + oy, 8, 8, BLUE); 
  tft.setCursor(77 + ox, 15 + oy);
  tft.print("OUT:");
  tft.print(currentTempExt);
  tft.print((char)247);
  tft.print("C");

  // Séparateur fin
  tft.drawLine(0 + ox, 26 + oy, 128 + ox, 26 + oy, DRKGREY);

  // --- 3. GRAPHIQUE 1 : INTÉRIEUR (Y: 30 à 73) ---
  // x=22, y=30, largeur=105, hauteur=43
  drawSingleGraph(tempIntHistory, historyCount, 22, 30, 105, 43, RED);

  // --- 4. GRAPHIQUE 2 : EXTÉRIEUR (Y: 82 à 125) ---
  // Parfaitement espacé en dessous
  drawSingleGraph(tempExtHistory, historyCount, 22, 82, 105, 43, BLUE);
}

void drawSingleGraph(float* vals, int count, int x, int y, int w, int h, uint16_t color) {
  float minVal = vals[0];
  float maxVal = vals[0];
  
  for(int i = 1; i < count; i++) {
    if(vals[i] < minVal) minVal = vals[i];
    if(vals[i] > maxVal) maxVal = vals[i];
  }
  
  if(maxVal - minVal < 0.1) { maxVal += 0.5; minVal -= 0.5; }
  float range = maxVal - minVal;

  int maxI = (int)round(maxVal);
  int minI = (int)round(minVal);

  // --- COLONNE AXE Y (Confinée de X=0 à X=18) ---
  tft.setTextSize(1);
  tft.setTextColor(color); 
  
  // Texte Max
  tft.setCursor(0 + ox, y + oy);
  tft.print(maxI);
  tft.print((char)247); // °
  tft.print("C");
  
  // Texte Min
  tft.setCursor(0 + ox, y + h - 7 + oy);
  tft.print(minI);
  tft.print((char)247); // °
  tft.print("C");

  // Ligne verticale grise isolant le texte du graphique (La fin du 9C flottant)
  tft.drawLine(19 + ox, y + oy, 19 + ox, y + h + oy, DRKGREY);

  // --- CADRE ET GRILLES DU GRAPHIQUE ---
  tft.drawRect(x + ox, y + oy, w, h, WHITE); 
  tft.drawLine(x + ox, y + (h/2) + oy, x + w + ox, y + (h/2) + oy, DRKGREY);

  // --- LIGNES DE DONNÉES ---
  for(int i = 0; i < count - 1; i++) {
    int x1 = x + (i * (w / (float)(count-1)));
    int x2 = x + ((i+1) * (w / (float)(count-1)));
    
    int y1 = y + h - ((vals[i] - minVal) / range * h);
    int y2 = y + h - ((vals[i+1] - minVal) / range * h);
    
    // Ligne double épaisseur
    tft.drawLine(x1 + ox, y1 + oy, x2 + ox, y2 + oy, color);
    tft.drawLine(x1 + ox, y1 + 1 + oy, x2 + ox, y2 + 1 + oy, color);
  }
}

// -----------------------------------------------------------------------------
// Les fonctions Arduino Cloud générées vont ici
// -----------------------------------------------------------------------------
